{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "frontier-wars",
  "post": {
    "dir": "public",
    "entrypoints": {
      "default": {
        "entry": "index.html",
        "height": "tall"
      }
    }
  },
  "server": {
    "entry": "index.cjs"
  },
  "permissions": {
    "redis": true,
    "reddit": {
      "enable": true,
      "scope": "user"
    }
  },
  "marketingAssets": { "icon": "assets/frontier-icon.png" },
  "scheduler": {
    "tasks": {
      "siege-tick": {
        "endpoint": "/internal/cron/siege-tick",
        "cron": "*/5 * * * *"
      }
    }
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/app-install"
  },
  "menu": {
    "items": [
      {
        "label": "Raise Frontier Anchor",
        "description": "Create this subreddit's territory post",
        "forUserType": "moderator",
        "location": [
          "subreddit"
        ],
        "endpoint": "/internal/menu/create-anchor"
      }
    ]
  },
  "dev": {
    "subreddit": "frontier_wars_dev"
  }
}